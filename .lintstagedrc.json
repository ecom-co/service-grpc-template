{
    "src/**/*.{js,jsx,ts,tsx}": [
        "eslint --fix --max-warnings 0 --no-warn-ignored",
        "npx prettier --write"
    ],
    "test/**/*.{js,jsx,ts,tsx}": [
        "eslint --fix --max-warnings 0 --no-warn-ignored",
        "npx prettier --write"
    ],
    "*.{json,yml,yaml}": [
        "npx prettier --write"
    ],
    "*.md": [
        "npx prettier --write"
    ],
    "package.json": [
        "npx prettier --write",
        "npx sort-package-json"
    ]
}